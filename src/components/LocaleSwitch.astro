---
// 文件说明：该文件渲染站点的语言切换按钮。
// 功能说明：在双语页面之间跳转，并保持当前语种的可见状态。
//
// 结构概览：
//   第一部分：解析组件参数
//   第二部分：输出语言切换 UI
interface Props {
	currentLocale: 'zh-cn' | 'en';
	href: string;
}

const { currentLocale, href } = Astro.props;
---

<a
	href={href}
	class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm text-slate-600 shadow-[0_4px_12px_rgba(15,23,42,0.06)] transition duration-300 hover:border-slate-300 hover:bg-slate-50"
>
	<span class:list={['rounded-full px-2 py-1 text-[11px]', currentLocale === 'zh-cn' ? 'bg-blue-50 text-blue-700' : 'text-slate-500']}>中</span>
	<span class:list={['rounded-full px-2 py-1 text-[11px]', currentLocale === 'en' ? 'bg-blue-50 text-blue-700' : 'text-slate-500']}>EN</span>
</a>

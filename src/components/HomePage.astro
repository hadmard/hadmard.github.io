---
import Layout from '../layouts/Layout.astro';
import SiteHeader from './SiteHeader.astro';
import { getCopy, localePath } from '../utils/i18n';

const { locale } = Astro.props;
const copy = getCopy(locale);
const alternatePath = locale === 'zh-cn' ? '/en/' : '/';
---

<Layout
    title={copy.seo.title}
    description={copy.seo.description}
    lang={locale}
    canonicalPath={localePath(locale)}
    alternatePath={alternatePath}
>
    <main class="site-shell">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <section class="hero-particle-wrap mt-10 sm:mt-12" data-reveal>
            <canvas id={`particle-canvas-${locale}`} class="hero-particle-canvas" aria-hidden="true"></canvas>
            <div class="hero-particle-panel mx-auto flex min-h-[480px] max-w-5xl flex-col items-center justify-center px-6 py-16 text-center sm:min-h-[560px] sm:px-10 sm:py-20">
                <p class="soft-label mb-6">{copy.hero?.badge || 'YFCCCC.GITHUB.IO'}</p>
                <h1 class="hero-title max-w-4xl font-semibold text-white">
                    {copy.hero?.title}
                </h1>
                <p class="hero-subtitle mt-5 max-w-3xl text-white/85">
                    {copy.hero?.description}
                </p>
                <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
                    <span class="inline-flex items-center rounded-full border border-white/22 bg-white/12 px-5 py-2.5 text-[14px] text-white">
                        {copy.hero?.primaryCta || (locale === 'zh-cn' ? '请使用右上角导航' : 'Use top-right navigation')}
                    </span>
                    <span class="inline-flex items-center rounded-full bg-[#0071e3] px-5 py-2.5 text-[14px] text-white">
                        {copy.hero?.secondaryCta || (locale === 'zh-cn' ? '仅通过栏目进入子页面' : 'Open subpages from top navigation only')}
                    </span>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script is:inline>
    (() => {
        const canvas = document.querySelector('.hero-particle-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const particles = [];
        let width = 0;
        let height = 0;
        let raf = 0;

        const init = () => {
            const rect = canvas.getBoundingClientRect();
            width = rect.width;
            height = rect.height;
            canvas.width = Math.floor(width * window.devicePixelRatio);
            canvas.height = Math.floor(height * window.devicePixelRatio);
            ctx.setTransform(window.devicePixelRatio, 0, 0, window.devicePixelRatio, 0, 0);

            particles.length = 0;
            const density = width < 640 ? 42 : 74;
            for (let i = 0; i < density; i += 1) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    vx: (Math.random() - 0.5) * 0.22,
                    vy: (Math.random() - 0.5) * 0.22,
                    r: Math.random() * 1.5 + 0.5,
                });
            }
        };

        const draw = () => {
            ctx.clearRect(0, 0, width, height);

            for (const p of particles) {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > width) p.vx *= -1;
                if (p.y < 0 || p.y > height) p.vy *= -1;

                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(255,255,255,0.58)';
                ctx.fill();
            }

            for (let i = 0; i < particles.length; i += 1) {
                for (let j = i + 1; j < particles.length; j += 1) {
                    const a = particles[i];
                    const b = particles[j];
                    const dx = a.x - b.x;
                    const dy = a.y - b.y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < 118) {
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y);
                        ctx.lineTo(b.x, b.y);
                        ctx.strokeStyle = `rgba(255,255,255,${(1 - d / 118) * 0.15})`;
                        ctx.lineWidth = 0.8;
                        ctx.stroke();
                    }
                }
            }

            raf = requestAnimationFrame(draw);
        };

        init();
        draw();
        window.addEventListener('resize', init);
        window.addEventListener('beforeunload', () => cancelAnimationFrame(raf));
    })();
</script>

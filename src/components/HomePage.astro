---
// 文件说明：该文件负责渲染首页的四大核心模块。
// 功能说明：把个人简历、项目经历、投资记录与个人思考组织成统一的叙事页面。
//
// 结构概览：
//   第一部分：导入依赖与解析参数
//   第二部分：准备首页文案与链接
//   第三部分：输出首页主结构
import type { CollectionEntry } from 'astro:content';

import type { Locale } from '../data/site';

import Layout from '../layouts/Layout.astro';
import { getCopy, getThoughtSlug, localePath } from '../utils/i18n';
import LocaleSwitch from './LocaleSwitch.astro';

interface Props {
	locale: Locale;
	thoughts: CollectionEntry<'thoughts'>[];
}

const { locale, thoughts } = Astro.props;
const copy = getCopy(locale);
const alternatePath = locale === 'zh-cn' ? '/en/' : '/';
const featuredThoughts = thoughts.filter((entry) => entry.data.featured).slice(0, 3);
const hasProjects = copy.projects.items.length > 0;
const hasInvestmentPrinciples = copy.investments.principles.length > 0;
const hasInvestmentRecords = copy.investments.records.length > 0;
const hasThoughts = featuredThoughts.length > 0;
---

<Layout
	title={copy.seo.title}
	description={copy.seo.description}
	lang={locale}
	canonicalPath={localePath(locale)}
	alternatePath={alternatePath}
>
	<main class="site-shell gap-8">
		<header class="panel sticky top-4 z-30 flex flex-wrap items-center justify-between gap-4 rounded-full px-4 py-3">
			<div class="flex flex-col">
				<span class="text-sm font-medium text-white">{copy.brand.name}</span>
				<span class="text-xs uppercase tracking-[0.28em] text-white/45">{copy.brand.caption}</span>
			</div>
			<nav class="flex flex-wrap items-center gap-1">
				{
					copy.nav.map((item) => (
						<a class="nav-link" href={`#${item.id}`}>
							{item.label}
						</a>
					))
				}
			</nav>
			<LocaleSwitch currentLocale={locale} href={alternatePath} />
		</header>

		<section class="hero-gradient panel-strong overflow-hidden rounded-[36px] px-6 py-8 sm:px-8 lg:px-10 lg:py-10">
			<div class="grid gap-8 lg:grid-cols-[1.2fr_0.9fr]">
				<div class="relative z-10 flex flex-col gap-6">
					<span class="soft-label w-fit">{copy.hero.badge}</span>
					<div class="space-y-4">
						<p class="text-sm uppercase tracking-[0.32em] text-[color:var(--color-mint)]">{copy.hero.eyebrow}</p>
						<h1 class="max-w-4xl font-display text-5xl leading-[0.95] text-white sm:text-6xl lg:text-7xl">
							{copy.hero.title}
						</h1>
						<p class="max-w-2xl text-base leading-8 text-white/72 sm:text-lg">{copy.hero.description}</p>
					</div>
					<div class="flex flex-wrap gap-3">
						<a class="inline-flex items-center rounded-full bg-white px-5 py-3 text-sm font-medium text-slate-950 transition hover:scale-[1.02]" href="#projects">
							{copy.hero.primaryCta}
						</a>
						<a class="inline-flex items-center rounded-full border border-white/14 px-5 py-3 text-sm text-white/82 transition hover:bg-white/8" href="#thinking">
							{copy.hero.secondaryCta}
						</a>
					</div>
					<div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.2em] text-white/54">
						{copy.hero.modes.map((mode) => <span class="signal-pill">{mode}</span>)}
					</div>
					<div class="grid gap-3 sm:grid-cols-2">
						{
							copy.hero.contacts.map((contact) => (
								<a class="rounded-[20px] border border-white/10 bg-black/18 px-4 py-4 transition hover:border-white/18 hover:bg-white/8" href={contact.href}>
									<p class="text-[11px] uppercase tracking-[0.28em] text-white/42">{contact.label}</p>
									<p class="mt-2 text-sm text-white/84">{contact.value}</p>
								</a>
							))
						}
					</div>
				</div>

				<div class="grid gap-4 self-end">
					<div class="metric-card min-h-[180px]">
						<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--color-mint)]">Signal Matrix</p>
						<div class="mt-5 grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
							{
								copy.hero.metrics.map((metric) => (
									<div class="border-b border-white/10 pb-4 last:border-b-0 last:pb-0">
										<p class="text-xs uppercase tracking-[0.25em] text-white/45">{metric.label}</p>
										<p class="mt-2 text-2xl font-medium text-white">{metric.value}</p>
										<p class="mt-2 text-sm leading-6 text-white/62">{metric.note}</p>
									</div>
								))
							}
						</div>
					</div>

					<div class="metric-card shimmer-line">
						<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--color-gold)]">Operating Log</p>
						<div class="mt-4 space-y-4">
							{
								copy.hero.terminal.map((item) => (
									<div class="rounded-2xl border border-white/10 bg-black/18 px-4 py-4">
										<div class="flex items-center justify-between gap-4">
											<p class="text-xs uppercase tracking-[0.25em] text-white/45">{item.label}</p>
											<span class="h-2.5 w-2.5 rounded-full bg-[color:var(--color-mint)]"></span>
										</div>
										<p class="mt-3 text-lg text-white">{item.value}</p>
										<p class="mt-2 text-sm leading-6 text-white/62">{item.note}</p>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="resume" class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr]">
			<div class="panel-strong rounded-[32px] p-6 sm:p-8">
				<p class="section-kicker">{copy.resume.kicker}</p>
				<h2 class="section-title mt-4">{copy.resume.title}</h2>
				<p class="mt-4 max-w-xl text-base leading-8 text-white/72">{copy.resume.intro}</p>
				<div class="mt-8 flex flex-wrap gap-3">
					{copy.resume.capsules.map((capsule) => <span class="signal-pill">{capsule}</span>)}
				</div>
			</div>
			<div class="panel rounded-[32px] p-6 sm:p-8">
				<div class="space-y-5">
					{
						copy.resume.timeline.map((item) => (
							<article class="story-card">
								<p class="text-xs uppercase tracking-[0.3em] text-[color:var(--color-sky)]">{item.period}</p>
								<h3 class="mt-3 text-2xl text-white">{item.title}</h3>
								<p class="mt-3 text-base leading-7 text-white/70">{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="projects" class="panel-strong rounded-[32px] p-6 sm:p-8">
			<div class="max-w-3xl">
				<p class="section-kicker">{copy.projects.kicker}</p>
				<h2 class="section-title mt-4">{copy.projects.title}</h2>
				<p class="mt-4 text-base leading-8 text-white/72">{copy.projects.intro}</p>
			</div>
			<div class="mt-8 grid gap-5 xl:grid-cols-3">
				{
					hasProjects ? (
						copy.projects.items.map((item, index) => (
							<article class="panel rounded-[28px] p-6">
								<div class="flex items-center justify-between gap-4">
									<span class="soft-label">0{index + 1}</span>
									<span class="text-xs uppercase tracking-[0.3em] text-white/45">{item.role}</span>
								</div>
								<h3 class="mt-5 text-3xl text-white">{item.name}</h3>
								<p class="mt-4 text-base leading-7 text-white/70">{item.summary}</p>
								<div class="mt-5 flex flex-wrap gap-2">
									{item.stack.map((stack) => <span class="signal-pill">{stack}</span>)}
								</div>
								<p class="mt-5 rounded-2xl border border-white/10 bg-black/18 px-4 py-4 text-sm leading-6 text-white/68">{item.impact}</p>
							</article>
						))
					) : (
						<article class="panel rounded-[28px] p-8 xl:col-span-3">
							<span class="soft-label">Soon</span>
							<h3 class="mt-5 text-3xl text-white">{copy.projects.emptyTitle}</h3>
							<p class="mt-4 max-w-3xl text-base leading-8 text-white/72">{copy.projects.emptyDescription}</p>
						</article>
					)
				}
			</div>
		</section>

		<section id="investments" class="grid gap-6 lg:grid-cols-[0.84fr_1.16fr]">
			<div class="panel-strong rounded-[32px] p-6 sm:p-8">
				<p class="section-kicker">{copy.investments.kicker}</p>
				<h2 class="section-title mt-4">{copy.investments.title}</h2>
				<p class="mt-4 text-base leading-8 text-white/72">{copy.investments.intro}</p>
				{
					hasInvestmentPrinciples ? (
						<div class="mt-8 space-y-3">
							{copy.investments.principles.map((item) => <div class="story-card text-base leading-7 text-white/78">{item}</div>)}
						</div>
					) : (
						<div class="story-card mt-8">
							<h3 class="text-2xl text-white">{copy.investments.emptyTitle}</h3>
							<p class="mt-3 text-base leading-7 text-white/72">{copy.investments.emptyDescription}</p>
						</div>
					)
				}
			</div>
			<div class="panel rounded-[32px] p-6 sm:p-8">
				<div class="mb-5 flex items-center justify-between gap-4">
					<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--color-gold)]">Capital Ledger</p>
					<span class="signal-pill">Public-safe format</span>
				</div>
				{
					hasInvestmentRecords ? (
						<div class="space-y-2">
							{
								copy.investments.records.map((record) => (
									<div class="data-row">
										<div>
											<p class="text-xs uppercase tracking-[0.25em] text-white/42">Asset</p>
											<p class="mt-2 text-base text-white">{record.asset}</p>
										</div>
										<div>
											<p class="text-xs uppercase tracking-[0.25em] text-white/42">Focus</p>
											<p class="mt-2 text-base text-white">{record.focus}</p>
										</div>
										<div>
											<p class="text-xs uppercase tracking-[0.25em] text-white/42">Thesis</p>
											<p class="mt-2 text-base leading-7 text-white/72">{record.thesis}</p>
										</div>
										<div>
											<p class="text-xs uppercase tracking-[0.25em] text-white/42">Rhythm</p>
											<p class="mt-2 text-base text-white">{record.rhythm}</p>
										</div>
									</div>
								))
							}
						</div>
					) : (
						<div class="rounded-[24px] border border-white/10 bg-black/18 px-5 py-6">
							<p class="text-base leading-7 text-white/72">{copy.investments.emptyDescription}</p>
						</div>
					)
				}
			</div>
		</section>

		<section id="thinking" class="panel-strong rounded-[32px] p-6 sm:p-8">
			<div class="max-w-3xl">
				<p class="section-kicker">{copy.thinking.kicker}</p>
				<h2 class="section-title mt-4">{copy.thinking.title}</h2>
				<p class="mt-4 text-base leading-8 text-white/72">{copy.thinking.intro}</p>
			</div>
			<div class="mt-8 grid gap-5 lg:grid-cols-3">
				{
					hasThoughts ? (
						featuredThoughts.map((entry) => (
							<a class="panel rounded-[28px] p-6 transition duration-300 hover:-translate-y-1 hover:bg-white/10" href={localePath(locale, `/thinking/${getThoughtSlug(entry)}`)}>
								<div class="flex items-center justify-between gap-4">
									<span class="soft-label">{entry.data.readingTime}</span>
									<span class="text-xs uppercase tracking-[0.28em] text-white/45">{entry.data.publishedAt.toLocaleDateString(locale === 'zh-cn' ? 'zh-CN' : 'en-US')}</span>
								</div>
								<h3 class="mt-5 text-3xl text-white">{entry.data.title}</h3>
								<p class="mt-4 text-base leading-7 text-white/70">{entry.data.excerpt}</p>
								<div class="mt-5 flex flex-wrap gap-2">
									{entry.data.tags.map((tag) => <span class="signal-pill">{tag}</span>)}
								</div>
								<p class="mt-6 text-sm uppercase tracking-[0.28em] text-[color:var(--color-mint)]">{copy.thinking.readMore}</p>
							</a>
						))
					) : (
						<article class="panel rounded-[28px] p-8 lg:col-span-3">
							<span class="soft-label">Editorial</span>
							<h3 class="mt-5 text-3xl text-white">{copy.thinking.emptyTitle}</h3>
							<p class="mt-4 max-w-3xl text-base leading-8 text-white/72">{copy.thinking.emptyDescription}</p>
						</article>
					)
				}
			</div>
		</section>

		<footer class="panel rounded-[32px] px-6 py-8 sm:px-8">
			<h2 class="font-display text-4xl leading-none text-white">{copy.footer.title}</h2>
			<p class="mt-4 max-w-3xl text-base leading-8 text-white/72">{copy.footer.description}</p>
			<p class="mt-4 text-sm uppercase tracking-[0.2em] text-white/46">{copy.footer.note}</p>
		</footer>
	</main>
</Layout>

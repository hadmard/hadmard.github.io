---
import Layout from '../layouts/Layout.astro';
import SiteHeader from './SiteHeader.astro';
import { getCopy, localePath } from '../utils/i18n';
import LearningMap from './LearningMap';

const { locale, thoughts } = Astro.props;
const copy = getCopy(locale);
const alternatePath = locale === 'zh-cn' ? '/en/' : '/';
---

<Layout
    title={copy.seo.title}
    description={copy.seo.description}
    lang={locale}
    canonicalPath={localePath(locale)}
    alternatePath={alternatePath}
>
    <!-- Global abstract dark space overlay -->
    <div class="fixed inset-0 z-[-1] min-h-screen bg-[url('https://images.unsplash.com/photo-1614850523459-c2f4c699c52e?q=80&w=2670&auto=format&fit=crop')] bg-cover bg-center bg-no-repeat opacity-20 mix-blend-screen pointer-events-none"></div>

    <main class="site-shell mx-auto px-4 sm:px-8 lg:px-12 py-8 min-h-screen flex flex-col relative z-10 w-full">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <!-- Premium Apple/Meta style Hero Section -->
        <section class="max-w-6xl mx-auto w-full mt-16 sm:mt-32 mb-24 px-4 isolate">
            <div class="space-y-6 sm:space-y-10 animate-in fade-in slide-in-from-bottom-8 duration-1000 ease-out fill-mode-both">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/20 bg-white/5 backdrop-blur-md text-xs font-semibold tracking-widest text-[#a855f7] uppercase leading-none shadow-[0_0_15px_rgba(168,85,247,0.3)]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
                    {copy.hero?.badge || 'HADMARD.GITHUB.IO'}
                </div>
                
                <h1 class="text-5xl sm:text-6xl md:text-8xl font-extrabold tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-white via-white/90 to-white/40 leading-[1.1] max-w-4xl">
                    {copy.hero?.title}
                </h1>
                
                <p class="text-lg sm:text-2xl text-white/50 font-light max-w-2xl leading-relaxed">
                    {copy.hero?.description}
                </p>
                
                <div class="flex flex-wrap gap-4 pt-4">
                    <a href={locale === 'zh-cn' ? '/resume/' : '/en/resume/'} class="group relative px-8 py-4 bg-white text-black font-semibold rounded-full overflow-hidden transition-transform duration-500 hover:scale-105 shadow-[0_0_40px_rgba(255,255,255,0.3)]">
                        <span class="relative z-10">{copy.hero?.primaryCta || (locale === 'zh-cn' ? '�鿴����' : 'View Resume')}</span>
                        <div class="absolute inset-0 bg-gradient-to-r from-gray-200 to-white opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </a>
                </div>
            </div>
        </section>

        <!-- Progress / Timeline Section -->
        <section class="max-w-7xl mx-auto w-full mt-10 mb-32 isolate" data-reveal>
            <div class="mb-10 text-center space-y-4">
                <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white/90">Path & Progress</h2>
                <p class="text-white/50 font-light text-lg max-w-2xl mx-auto">Interactive learning trajectory mapped over interconnected concepts.</p>
            </div>
            
            <div class="w-full relative rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-2xl border border-white/10 bg-black/60 shadow-[0_20px_80px_rgba(0,0,0,0.8)] backdrop-blur-3xl animate-in fade-in zoom-in duration-1000 fill-mode-both" style="animation-delay: 400ms">
                <!-- Inner glow effect -->
                <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent pointer-events-none z-10 rounded-[2rem] sm:rounded-[3rem]"></div>
                
                <div class="relative w-full h-[75vh] sm:h-[85vh]">
                   <LearningMap client:load />
                </div>
            </div>
        </section>

    </main>
</Layout>

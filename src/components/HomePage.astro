---
import Layout from '../layouts/Layout.astro';
import SiteHeader from './SiteHeader.astro';
import { getCopy, localePath } from '../utils/i18n';
import LearningMap from './LearningMap';

const { locale, thoughts } = Astro.props;
const copy = getCopy(locale);
const alternatePath = locale === 'zh-cn' ? '/en/' : '/';
---

<Layout
    title={copy.seo.title}
    description={copy.seo.description}
    lang={locale}
    canonicalPath={localePath(locale)}
    alternatePath={alternatePath}
>
    <!-- Use a simple non-techy container -->
    <main class="site-shell mx-auto px-4 py-8">
        <SiteHeader locale={locale} alternatePath={alternatePath} />
        
        <section class="max-w-7xl mx-auto w-full mt-6">
            <!-- Minecraft UI wrapped Learning Map -->
            <div class="mc-bg p-2 sm:p-4 rounded shadow-2xl">
                <div class="mc-bg-inset p-1 sm:p-3 relative overflow-hidden">
                   <LearningMap client:load />
                </div>
            </div>
        </section>
    </main>
</Layout>

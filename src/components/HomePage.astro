---
// 文件说明：该文件负责渲染首页的四大核心模块。
// 功能说明：在保留双语与结构的前提下，采用更简洁、疏朗的排版来展示个人主页。
//
// 结构概览：
//   第一部分：导入依赖与解析参数
//   第二部分：读取首页所需的本地同步数据
//   第三部分：准备首页文案与状态
//   第四部分：输出首页主结构
import { readFile } from 'node:fs/promises';
import path from 'node:path';
import process from 'node:process';

import type { CollectionEntry } from 'astro:content';

import type { Locale } from '../data/site';

import Layout from '../layouts/Layout.astro';
import { getCopy, getThoughtSlug, localePath } from '../utils/i18n';
import LocaleSwitch from './LocaleSwitch.astro';

interface Props {
	locale: Locale;
	thoughts: CollectionEntry<'thoughts'>[];
}

interface SyncedTopicRecord {
	sourceUrl?: string;
	title?: string;
	boardId?: number;
	boardName?: string;
	authorName?: string;
	createdAt?: string;
	replyCount?: number;
	hitCount?: number;
}

interface SyncedSummaryRecord {
	sourceUrl?: string;
	crawledAt?: string;
	topic?: SyncedTopicRecord;
	postCount?: number;
}

interface SyncedPostRecord {
	id?: number;
	postId?: number;
	userName?: string | null;
	content?: string;
	time?: string;
	replyTime?: string;
	floor?: number;
	isDeleted?: boolean;
}

async function readJsonFile<T>(filePath: string): Promise<T | null> {
	try {
		const raw = await readFile(filePath, 'utf8');
		return JSON.parse(raw) as T;
	} catch {
		return null;
	}
}

async function loadSyncedInvestmentFeed() {
	const baseDir = path.resolve(process.cwd(), 'custom/cc98-investment-crawler/output/topic-6450962');
	const summary = await readJsonFile<SyncedSummaryRecord>(path.join(baseDir, 'records/investment-summary.json'));
	const topic = summary?.topic ?? (await readJsonFile<SyncedTopicRecord>(path.join(baseDir, 'raw/topic.json')));
	const postPages = await readJsonFile<Array<{ items?: SyncedPostRecord[] }>>(path.join(baseDir, 'raw/posts.json'));
	const posts = (postPages ?? [])
		.flatMap((page) => page.items ?? [])
		.map((post, index) => ({
			floor: post.floor ?? index + 1,
			userName: post.isDeleted ? '已删除用户' : post.userName || '未知用户',
			content: post.isDeleted ? '[该楼层已删除]' : post.content || '[空内容]',
			time: post.replyTime || post.time || '',
			postId: post.postId ?? post.id ?? null,
			isDeleted: Boolean(post.isDeleted),
		}));

	if (!topic || posts.length === 0) {
		return null;
	}

	return {
		sourceLabel: 'cc98.org',
		sourceUrl: summary?.sourceUrl ?? topic.sourceUrl ?? 'https://www.cc98.org/topic/6450962',
		topic,
		posts,
	};
}

function formatSyncedTime(value: string, locale: Locale) {
	if (!value) {
		return locale === 'zh-cn' ? '时间未知' : 'Unknown time';
	}

	const date = new Date(value);
	if (Number.isNaN(date.getTime())) {
		return value;
	}

	return date.toLocaleString(locale === 'zh-cn' ? 'zh-CN' : 'en-US', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
		hour: '2-digit',
		minute: '2-digit',
		second: '2-digit',
		hour12: false,
	});
}

const { locale, thoughts } = Astro.props;
const copy = getCopy(locale);
const alternatePath = locale === 'zh-cn' ? '/en/' : '/';
const featuredThoughts = thoughts.filter((entry) => entry.data.featured).slice(0, 3);
const syncedInvestmentFeed = await loadSyncedInvestmentFeed();
const hasProjects = copy.projects.items.length > 0;
const hasInvestmentPrinciples = copy.investments.principles.length > 0;
const hasInvestmentRecords = copy.investments.records.length > 0;
const hasSyncedInvestmentRecords = Boolean(syncedInvestmentFeed && syncedInvestmentFeed.posts.length > 0);
const hasThoughts = featuredThoughts.length > 0;
const investmentUi =
	locale === 'zh-cn'
		? {
				title: '投资记录已同步到站点首页。',
				intro: '以下内容直接来自你在 cc98.org 的原帖，保留原文、楼层与发帖时间，构建后会同步进入 GitHub Pages。',
				sourceLabel: '来自 cc98.org',
				sourceLink: '查看原帖',
				authorLabel: '作者',
				updatedLabel: '最近更新',
				floorLabel: '楼',
				timeLabel: '时间',
				postIdLabel: '帖子 ID',
			}
		: {
				title: 'Investment notes are now synced on the homepage.',
				intro: 'The entries below come directly from your cc98.org thread, keeping the original text, floor number, and post time in the GitHub Pages build.',
				sourceLabel: 'From cc98.org',
				sourceLink: 'Open source thread',
				authorLabel: 'Author',
				updatedLabel: 'Latest update',
				floorLabel: 'Floor',
				timeLabel: 'Time',
				postIdLabel: 'Post ID',
			};
---

<Layout
	title={copy.seo.title}
	description={copy.seo.description}
	lang={locale}
	canonicalPath={localePath(locale)}
	alternatePath={alternatePath}
>
	<main class="site-shell gap-12">
		<header class="glass-topbar flex flex-wrap items-center justify-between gap-4">
			<div class="space-y-1">
				<p class="text-sm font-medium">{copy.brand.name}</p>
				<p class="text-sm" style="color: var(--color-ink-soft);">{copy.brand.caption}</p>
			</div>
			<div class="flex flex-wrap items-center gap-2 sm:gap-4">
				<nav class="flex flex-wrap items-center gap-1">
					{
						copy.nav.map((item) => (
							<a class="nav-link" href={`#${item.id}`}>
								{item.label}
							</a>
						))
					}
				</nav>
				<LocaleSwitch currentLocale={locale} href={alternatePath} />
			</div>
		</header>

		<section class="grid gap-8 lg:grid-cols-[1.5fr_0.9fr] lg:items-start">
			<div class="space-y-6">
				<span class="soft-label">{copy.hero.badge}</span>
				<div class="hero-lead space-y-4">
					<p class="section-kicker">{copy.hero.eyebrow}</p>
					<h1 class="max-w-4xl font-display text-5xl leading-[1.02] sm:text-6xl lg:text-7xl" style="color: var(--color-ink);">
						{copy.hero.title}
					</h1>
					<p class="max-w-3xl text-lg leading-8" style="color: var(--color-ink-soft);">{copy.hero.description}</p>
				</div>
				<div class="hero-subtle flex flex-wrap gap-2">
					{copy.hero.modes.slice(0, 3).map((mode) => <span class="signal-pill">{mode}</span>)}
				</div>
				<div class="hero-stage grid gap-3 sm:grid-cols-2">
					{
						copy.hero.contacts.map((contact) => (
							<a class="story-card block" href={contact.href}>
								<p class="text-[11px] uppercase tracking-[0.24em]" style="color: var(--color-ink-soft);">{contact.label}</p>
								<p class="mt-2 text-sm" style="color: var(--color-ink);">{contact.value}</p>
							</a>
						))
					}
				</div>
			</div>

			<aside class="hero-frame hero-stage">
				<div class="hero-orbit right-6 top-6 h-14 w-14"></div>
				<div class="hero-orbit bottom-8 right-20 h-8 w-8" style="animation-delay: -2s;"></div>
				<div class="hero-orbit bottom-14 right-6 h-5 w-5" style="animation-delay: -4s;"></div>
				<div class="space-y-5">
					{
						copy.hero.terminal.map((item) => (
							<div class="space-y-2 border-b pb-4 last:border-b-0 last:pb-0" style="border-color: var(--color-line);">
								<p class="text-[11px] uppercase tracking-[0.24em]" style="color: var(--color-ink-soft);">{item.label}</p>
								<p class="text-base leading-7" style="color: var(--color-ink);">{item.value}</p>
								<p class="text-sm leading-6" style="color: var(--color-ink-soft);">{item.note}</p>
							</div>
						))
					}
				</div>
			</aside>
		</section>

		<section id="resume" data-reveal class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="space-y-4">
				<p class="section-kicker">{copy.resume.kicker}</p>
				<h2 class="section-title">{copy.resume.title}</h2>
				<p class="text-base leading-8" style="color: var(--color-ink-soft);">{copy.resume.intro}</p>
				<div class="flex flex-wrap gap-2">
					{copy.resume.capsules.map((capsule) => <span class="signal-pill">{capsule}</span>)}
				</div>
			</div>
			<div class="space-y-4">
				{
					copy.resume.timeline.map((item) => (
						<article class="story-card">
							<p class="text-[11px] uppercase tracking-[0.24em]" style="color: var(--color-accent);">{item.period}</p>
							<h3 class="mt-3 text-xl" style="color: var(--color-ink);">{item.title}</h3>
							<p class="mt-3 text-base leading-7" style="color: var(--color-ink-soft);">{item.description}</p>
						</article>
					))
				}
			</div>
		</section>

		<section id="projects" data-reveal class="space-y-5">
			<div class="space-y-3">
				<p class="section-kicker">{copy.projects.kicker}</p>
				<h2 class="section-title">{copy.projects.title}</h2>
				<p class="max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">{copy.projects.intro}</p>
			</div>
			{
				hasProjects ? (
					<div class="grid gap-4 lg:grid-cols-2">
						{
							copy.projects.items.map((item) => (
								<article class="story-card">
									<p class="text-[11px] uppercase tracking-[0.24em]" style="color: var(--color-ink-soft);">{item.role}</p>
									<h3 class="mt-3 text-2xl" style="color: var(--color-ink);">{item.name}</h3>
									<p class="mt-3 text-base leading-7" style="color: var(--color-ink-soft);">{item.summary}</p>
									<div class="mt-4 flex flex-wrap gap-2">
										{item.stack.map((stack) => <span class="signal-pill">{stack}</span>)}
									</div>
									<p class="mt-4 text-sm leading-6" style="color: var(--color-ink-soft);">{item.impact}</p>
								</article>
							))
						}
					</div>
				) : (
					<div class="story-card">
						<h3 class="text-xl" style="color: var(--color-ink);">{copy.projects.emptyTitle}</h3>
						<p class="mt-3 max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">{copy.projects.emptyDescription}</p>
					</div>
				)
			}
		</section>

		<section id="investments" data-reveal class="space-y-5">
			<div class="space-y-3">
				<p class="section-kicker">{copy.investments.kicker}</p>
				<h2 class="section-title">{hasSyncedInvestmentRecords ? investmentUi.title : copy.investments.title}</h2>
				<p class="max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">
					{hasSyncedInvestmentRecords ? investmentUi.intro : copy.investments.intro}
				</p>
			</div>
			<div class="grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
				<div>
					{
						hasSyncedInvestmentRecords && syncedInvestmentFeed ? (
							<div class="story-card space-y-4">
								<div class="flex flex-wrap items-center gap-2">
									<span class="soft-label">{investmentUi.sourceLabel}</span>
									<a
										class="signal-pill"
										href={syncedInvestmentFeed.sourceUrl}
										target="_blank"
										rel="noreferrer"
									>
										{investmentUi.sourceLink}
									</a>
								</div>
								<div class="space-y-3">
									<h3 class="text-2xl" style="color: var(--color-ink);">{syncedInvestmentFeed.topic.title ?? 'CC98 投资记录'}</h3>
									<p class="text-sm leading-7" style="color: var(--color-ink-soft);">
										{investmentUi.authorLabel}：{syncedInvestmentFeed.topic.authorName ?? 'hadmard'}
									</p>
									<p class="text-sm leading-7" style="color: var(--color-ink-soft);">
										{investmentUi.updatedLabel}：{formatSyncedTime(syncedInvestmentFeed.posts[syncedInvestmentFeed.posts.length - 1]?.time ?? '', locale)}
									</p>
									<p class="text-sm leading-7" style="color: var(--color-ink-soft);">
										{locale === 'zh-cn' ? '总楼层' : 'Total floors'}：{syncedInvestmentFeed.posts.length}
									</p>
								</div>
							</div>
						) : hasInvestmentPrinciples ? (
							<div class="space-y-3">
								{copy.investments.principles.map((item) => <div class="story-card text-base leading-7" style="color: var(--color-ink-soft);">{item}</div>)}
							</div>
						) : (
							<div class="story-card">
								<h3 class="text-xl" style="color: var(--color-ink);">{copy.investments.emptyTitle}</h3>
								<p class="mt-3 text-base leading-7" style="color: var(--color-ink-soft);">{copy.investments.emptyDescription}</p>
							</div>
						)
					}
				</div>
				<div class="panel p-6">
					{
						hasSyncedInvestmentRecords && syncedInvestmentFeed ? (
							<div class="space-y-4">
								{
									syncedInvestmentFeed.posts.map((post) => (
										<article class="story-card">
											<div class="flex flex-wrap items-center justify-between gap-3">
												<div class="flex flex-wrap items-center gap-2">
													<span class="soft-label">
														{post.floor}
														{investmentUi.floorLabel}
													</span>
													<span class="signal-pill">{investmentUi.sourceLabel}</span>
												</div>
												<p class="text-[11px] uppercase tracking-[0.22em]" style="color: var(--color-ink-soft);">
													{formatSyncedTime(post.time, locale)}
												</p>
											</div>
											<div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm" style="color: var(--color-ink-soft);">
												<p>{investmentUi.timeLabel}：{formatSyncedTime(post.time, locale)}</p>
												<p>{investmentUi.postIdLabel}：{post.postId ?? 'N/A'}</p>
												<p>{investmentUi.authorLabel}：{post.userName}</p>
											</div>
											<div class="mt-5 whitespace-pre-wrap text-base leading-8" style="color: var(--color-ink);">
												{post.content}
											</div>
										</article>
									))
								}
							</div>
						) : hasInvestmentRecords ? (
							<div class="space-y-2">
								{
									copy.investments.records.map((record) => (
										<div class="data-row">
											<div>
												<p class="text-[11px] uppercase tracking-[0.24em]">Asset</p>
												<p class="mt-2 text-base" style="color: var(--color-ink);">{record.asset}</p>
											</div>
											<div>
												<p class="text-[11px] uppercase tracking-[0.24em]">Focus</p>
												<p class="mt-2 text-base" style="color: var(--color-ink);">{record.focus}</p>
											</div>
											<div>
												<p class="text-[11px] uppercase tracking-[0.24em]">Thesis</p>
												<p class="mt-2 text-base leading-7">{record.thesis}</p>
											</div>
											<div>
												<p class="text-[11px] uppercase tracking-[0.24em]">Rhythm</p>
												<p class="mt-2 text-base" style="color: var(--color-ink);">{record.rhythm}</p>
											</div>
										</div>
									))
								}
							</div>
						) : (
							<p class="text-base leading-8" style="color: var(--color-ink-soft);">{copy.investments.emptyDescription}</p>
						)
					}
				</div>
			</div>
		</section>

		<section id="thinking" data-reveal class="space-y-5">
			<div class="space-y-3">
				<p class="section-kicker">{copy.thinking.kicker}</p>
				<h2 class="section-title">{copy.thinking.title}</h2>
				<p class="max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">{copy.thinking.intro}</p>
			</div>
			{
				hasThoughts ? (
					<div class="grid gap-4 lg:grid-cols-2">
						{
							featuredThoughts.map((entry) => (
								<a class="story-card block" href={localePath(locale, `/thinking/${getThoughtSlug(entry)}`)}>
									<div class="flex items-center justify-between gap-4">
										<span class="soft-label">{entry.data.readingTime}</span>
										<span class="text-[11px] uppercase tracking-[0.24em]" style="color: var(--color-ink-soft);">
											{entry.data.publishedAt.toLocaleDateString(locale === 'zh-cn' ? 'zh-CN' : 'en-US')}
										</span>
									</div>
									<h3 class="mt-4 text-2xl" style="color: var(--color-ink);">{entry.data.title}</h3>
									<p class="mt-3 text-base leading-7" style="color: var(--color-ink-soft);">{entry.data.excerpt}</p>
								</a>
							))
						}
					</div>
				) : (
					<div class="story-card">
						<h3 class="text-xl" style="color: var(--color-ink);">{copy.thinking.emptyTitle}</h3>
						<p class="mt-3 max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">{copy.thinking.emptyDescription}</p>
					</div>
				)
			}
		</section>

		<footer data-reveal class="panel mt-4 px-6 py-8 sm:px-8">
			<h2 class="font-display text-3xl" style="color: var(--color-ink);">{copy.footer.title}</h2>
			<p class="mt-3 max-w-3xl text-base leading-8" style="color: var(--color-ink-soft);">{copy.footer.description}</p>
			<p class="mt-4 text-sm" style="color: var(--color-ink-soft);">{copy.footer.note}</p>
		</footer>
	</main>
</Layout>

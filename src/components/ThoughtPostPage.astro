---
// 文件说明：该文件负责渲染思考文章详情页。
// 功能说明：统一输出文章头图区域、正文排版、关联文章和评论入口。
//
// 结构概览：
//   第一部分：导入依赖与解析参数
//   第二部分：准备页面文案与路径
//   第三部分：输出文章详情结构
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../data/site';

import Layout from '../layouts/Layout.astro';
import { getCopy, getThoughtSlug, localePath } from '../utils/i18n';
import Comments from './Comments.astro';
import LocaleSwitch from './LocaleSwitch.astro';

const { locale, post, Content, related, alternateHref } = Astro.props as {
	locale: Locale;
	post: CollectionEntry<'thoughts'>;
	Content: any;
	related: CollectionEntry<'thoughts'>[];
	alternateHref: string;
};
const copy = getCopy(locale);
const articlePath = localePath(locale, `/thinking/${getThoughtSlug(post)}`);
---

<Layout
	title={`${post.data.title} | ${copy.brand.name}`}
	description={post.data.excerpt}
	lang={locale}
	canonicalPath={articlePath}
	alternatePath={alternateHref}
>
	<main class="site-shell gap-8">
		<header class="panel sticky top-4 z-30 flex flex-wrap items-center justify-between gap-4 rounded-full px-4 py-3">
			<div class="flex items-center gap-3 text-sm text-white/74">
				<a class="nav-link" href={localePath(locale)}>{copy.post.backLabel}</a>
				<span class="text-white/28">/</span>
				<span>{post.data.title}</span>
			</div>
			<LocaleSwitch currentLocale={locale} href={alternateHref} />
		</header>

		<section class="hero-gradient panel-strong rounded-[36px] px-6 py-8 sm:px-8 lg:px-10">
			<div class="max-w-4xl">
				<p class="section-kicker">{post.data.publishedAt.toLocaleDateString(locale === 'zh-cn' ? 'zh-CN' : 'en-US')}</p>
				<h1 class="mt-4 font-display text-5xl leading-[0.96] text-white sm:text-6xl">{post.data.title}</h1>
				<p class="mt-5 text-lg leading-8 text-white/74">{post.data.excerpt}</p>
				<div class="mt-6 flex flex-wrap gap-2">
					<span class="soft-label">{post.data.readingTime}</span>
					{post.data.tags.map((tag) => <span class="signal-pill">{tag}</span>)}
				</div>
			</div>
		</section>

		<section class="grid gap-6 lg:grid-cols-[1.1fr_0.55fr]">
			<article class="panel-strong rounded-[32px] px-6 py-8 sm:px-8 lg:px-10">
				<div class="prose-thought">
					<Content />
				</div>
			</article>
			<aside class="space-y-6">
				<div class="panel rounded-[28px] p-6">
					<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--color-mint)]">{copy.post.otherLocaleLabel}</p>
					<p class="mt-3 text-base leading-7 text-white/70">
						{locale === 'zh-cn'
							? '如果你需要把这篇内容展示给国际受众，可以直接切到英文版本。'
							: 'Switch to the parallel Chinese version whenever you want the native-language reading flow.'}
					</p>
					<a class="mt-5 inline-flex rounded-full border border-white/12 px-4 py-2 text-sm text-white/84 transition hover:bg-white/8" href={alternateHref}>
						{copy.post.otherLocaleLabel}
					</a>
				</div>
				<div class="panel rounded-[28px] p-6">
					<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--color-gold)]">{copy.post.relatedTitle}</p>
					<div class="mt-4 space-y-4">
						{
							related.map((entry) => (
								<a class="block rounded-2xl border border-white/10 bg-black/18 px-4 py-4 transition hover:border-white/20 hover:bg-white/8" href={localePath(locale, `/thinking/${getThoughtSlug(entry)}`)}>
									<p class="text-base text-white">{entry.data.title}</p>
									<p class="mt-2 text-sm leading-6 text-white/62">{entry.data.excerpt}</p>
								</a>
							))
						}
					</div>
				</div>
			</aside>
		</section>

		<Comments title={copy.thinking.commentTitle} note={copy.thinking.commentNote} />
	</main>
</Layout>

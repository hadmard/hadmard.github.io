---
// 文件说明：该文件负责渲染文章评论组件。
// 功能说明：当前默认使用 utterances 接入 GitHub Issues 评论，以便在没有额外后端的情况下直接可用。
//
// 结构概览：
//   第一部分：解析参数
//   第二部分：输出评论容器与脚本
interface Props {
	title: string;
	note: string;
}

const { title, note } = Astro.props;
---

<section class="panel rounded-[28px] p-6">
	<div class="max-w-3xl">
		<p class="section-kicker">{title}</p>
		<p class="mt-3 text-base leading-7 text-white/68">{note}</p>
	</div>
	<div class="mt-6 min-h-[220px] rounded-[24px] border border-white/10 bg-black/18 p-4">
		<div id="comments-root"></div>
	</div>
</section>

<script is:inline>
	const existing = document.querySelector('script[data-comments="utterances"]');
	if (!existing) {
		const script = document.createElement('script');
		script.src = 'https://utteranc.es/client.js';
		script.async = true;
		script.crossOrigin = 'anonymous';
		script.setAttribute('repo', 'hadmard/hadmard.github.io');
		script.setAttribute('issue-term', 'pathname');
		script.setAttribute('label', 'comment');
		script.setAttribute('theme', 'github-dark');
		script.setAttribute('data-comments', 'utterances');
		document.querySelector('#comments-root')?.appendChild(script);
	}
</script>

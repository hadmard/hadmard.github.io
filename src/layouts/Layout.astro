---
// 文件说明：该文件是全站通用布局。
// 功能说明：统一处理 SEO 元信息、全局样式、视图切换与页面外层结构。
//
// 结构概览：
//   第一部分：导入依赖与解析页面参数
//   第二部分：生成 canonical 与 alternate 元信息
//   第三部分：输出页面框架
import '../styles/global.css';

import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	lang: string;
	canonicalPath: string;
	alternatePath?: string;
}

const { title, description, lang, canonicalPath, alternatePath } = Astro.props;
const canonical = Astro.site ? new URL(canonicalPath, Astro.site).toString() : undefined;
const alternate = alternatePath && Astro.site ? new URL(alternatePath, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#07111f" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		{canonical && <link rel="canonical" href={canonical} />}
		{alternate && <link rel="alternate" hreflang={lang === 'zh-cn' ? 'en' : 'zh-CN'} href={alternate} />}
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<div class="ambient-layer ambient-layer-primary" aria-hidden="true"></div>
		<div class="ambient-layer ambient-layer-secondary" aria-hidden="true"></div>
		<div class="ambient-grid" aria-hidden="true"></div>
		<slot />
		<script is:inline>
			const setupReveal = () => {
				const items = document.querySelectorAll('[data-reveal]');
				if (!items.length) return;

				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
				);

				for (const item of items) {
					observer.observe(item);
				}
			};

			document.addEventListener('astro:page-load', setupReveal);
			document.addEventListener('DOMContentLoaded', setupReveal);
		</script>
	</body>
</html>

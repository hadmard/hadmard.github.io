---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import LearningMap from '../components/LearningMap';
import { getCopy } from '../utils/i18n';

const locale = 'zh-cn';
const copy = getCopy(locale);
const alternatePath = '/en/progress/';
---

<Layout
  title={`进度 | ${copy.brand.name}`}
  description={copy.seo.description}
  lang={locale}
  canonicalPath="/progress/"
  alternatePath={alternatePath}
>
  <main class="site-shell">
    <SiteHeader locale={locale} alternatePath={alternatePath} />

    <section class="mx-auto mt-12 mb-8 w-full max-w-5xl" data-reveal>
      <div class="panel-strong p-8 sm:p-12">
        <p class="soft-label mb-5">Progress · Left to Right Depth</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-5xl">学习进度（从左到右）</h1>
        <p class="mt-4 max-w-3xl text-slate-600 leading-8">
          这里的结构按“知识深度”横向展开：同一列代表并列能力，列与列之间代表递进关系。
        </p>
      </div>
    </section>

    <section class="mx-auto mb-16 w-full max-w-5xl" data-reveal>
      <div class="panel overflow-hidden rounded-3xl">
        <div class="relative w-full h-[70vh] sm:h-[78vh]">
          <LearningMap client:load />
        </div>
      </div>
    </section>

    <section class="mx-auto mb-24 w-full max-w-5xl" data-reveal>
      <div class="panel p-8 sm:p-10">
        <p class="section-kicker">Internship Goal</p>
        <h2 class="section-title mt-3">实习目标放在进度汇总端</h2>

        <div class="mt-8 border-t border-slate-200/80">
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-slate-900">数学 1 → 数学 2 → 数学 3</div>
            <div>基础链路（递进）</div>
          </article>
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-slate-900">算法线 / 系统线 / 深度学习线</div>
            <div>中段能力（并列）</div>
          </article>
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-slate-900">科研实习汇总目标</div>
            <div>Google / Meta / Jane Street 等国际大厂实习作为终端汇总目标。</div>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

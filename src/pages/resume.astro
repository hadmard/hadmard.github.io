---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getCopy } from '../utils/i18n';

const locale = 'zh-cn';
const copy = getCopy(locale);
const alternatePath = '/en/' + 'resume/';
---

<Layout
    title={`${copy.nav.find((i) => i.id === 'resume')?.label || 'resume'} | ${copy.brand.name}`}
    description={copy.seo.description}
    lang={locale}
    canonicalPath="/resume/"
    alternatePath={alternatePath}
>
    <main class="site-shell">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <section id="resume" class="mx-auto mt-12 mb-8 w-full max-w-5xl" data-reveal>
            <div class="panel-strong p-8 sm:p-12">
                <p class="soft-label mb-5">Apple Clean Layout · Google Friendly Colors</p>
                <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{copy['resume']?.title || 'resume'}</h1>
                <p class="mt-4 max-w-3xl text-slate-600 leading-8">{copy['resume']?.intro || ''}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                    <span class="signal-pill">视觉算法主线</span>
                    <span class="signal-pill">工程与研究并行</span>
                    <span class="signal-pill">跨学科学习</span>
                </div>
            </div>
        </section>

        <section class="mx-auto mb-24 w-full max-w-5xl" data-reveal>
            <div class="panel p-8 sm:p-10">
                <h2 class="text-xl font-semibold text-slate-900">页面说明</h2>
                <p class="mt-3 text-slate-600 leading-8">
                    这一版使用浅底、深字、低噪阴影和蓝色强调，让信息密度更易读，视觉上更接近你说的 Google 配色与 Apple 式简洁。
                </p>
                <p class="mt-3 text-slate-600 leading-8">
                    下一步可以在此基础上补齐教育经历、研究方向、技能栈与成果条目，形成完整履历页面。
                </p>
                </div>
        </section>
    </main>
</Layout>

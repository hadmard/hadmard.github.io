---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getCopy } from '../utils/i18n';

const locale = 'zh-cn';
const copy = getCopy(locale);
const alternatePath = '/en/' + 'projects/';
---

<Layout
    title={`${copy.nav.find((i) => i.id === 'projects')?.label || 'projects'} | ${copy.brand.name}`}
    description={copy.seo.description}
    lang={locale}
    canonicalPath="/projects/"
    alternatePath={alternatePath}
>
    <main class="site-shell">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <section id="projects" class="mx-auto mt-10 w-full max-w-6xl" data-reveal>
            <div class="rounded-xl bg-black px-8 py-14 text-white sm:px-12 sm:py-20">
                <p class="soft-label mb-5">Projects</p>
                <h1 class="hero-title max-w-4xl font-semibold">{copy['projects']?.title || 'projects'}</h1>
                <p class="mt-5 max-w-3xl text-[17px] leading-[1.47] text-white/82">{copy['projects']?.intro || ''}</p>
                <div class="mt-8 flex flex-wrap gap-2">
                    <span class="inline-flex items-center rounded-full border border-white/18 bg-white/10 px-4 py-1.5 text-[12px] text-white">结构化案例</span>
                    <span class="inline-flex items-center rounded-full border border-white/18 bg-white/10 px-4 py-1.5 text-[12px] text-white">方法可复盘</span>
                    <span class="inline-flex items-center rounded-full border border-white/18 bg-white/10 px-4 py-1.5 text-[12px] text-white">结果可验证</span>
                </div>
            </div>
        </section>

        <section class="mx-auto mb-24 mt-6 w-full max-w-6xl" data-reveal>
            <div class="rounded-xl bg-[#f5f5f7] p-8 sm:p-12">
                <h2 class="section-title">模块状态</h2>
                <div class="mt-8 border-t border-black/12">
                    <article class="data-row md:grid-cols-[1fr_2fr]">
                        <div class="font-semibold text-[#1d1d1f]">当前状态</div>
                        <div>项目模块正在建设中，优先等待可公开且完整的代表作。</div>
                    </article>
                    <article class="data-row md:grid-cols-[1fr_2fr]">
                        <div class="font-semibold text-[#1d1d1f]">推荐结构</div>
                        <div>每个项目统一为背景、目标、方法、结果、复盘五段，保持阅读节奏一致。</div>
                    </article>
                    <article class="data-row md:grid-cols-[1fr_2fr]">
                        <div class="font-semibold text-[#1d1d1f]">下一步</div>
                        <div>补首批 2 到 3 个完整案例后，再扩展筛选和多项目导航。</div>
                    </article>
                </div>
                </div>
        </section>
    </main>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { getCopy } from '../../utils/i18n';

const locale = 'en';
const copy = getCopy(locale);
const alternatePath = '/' + 'resume/';
---

<Layout
    title={`${copy.nav.find((i) => i.id === 'resume')?.label || 'resume'} | ${copy.brand.name}`}
    description={copy.seo.description}
    lang={locale}
    canonicalPath="/en/resume/"
    alternatePath={alternatePath}
>
    <main class="site-shell">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <section id="resume" class="mx-auto mt-12 mb-8 w-full max-w-5xl" data-reveal>
            <div class="panel-strong p-8 sm:p-12">
                <p class="soft-label mb-5">Apple Clean Layout · Google Friendly Colors</p>
                <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{copy['resume']?.title || 'resume'}</h1>
                <p class="mt-4 max-w-3xl text-slate-600 leading-8">{copy['resume']?.intro || ''}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                    <span class="signal-pill">Visual Algorithms</span>
                    <span class="signal-pill">Research + Engineering</span>
                    <span class="signal-pill">Interdisciplinary Growth</span>
                </div>
            </div>
        </section>

        <section class="mx-auto mb-24 w-full max-w-5xl" data-reveal>
            <div class="panel p-8 sm:p-10">
                <h2 class="text-xl font-semibold text-slate-900">Page Notes</h2>
                <p class="mt-3 text-slate-600 leading-8">
                    This revision uses readable contrast, subtle shadows, and one consistent accent color, closer to the clean Apple and Google style direction.
                </p>
                <p class="mt-3 text-slate-600 leading-8">
                    The next step is filling this page with structured resume blocks: education, focus areas, skills, and outcomes.
                </p>
                </div>
        </section>
    </main>
</Layout>

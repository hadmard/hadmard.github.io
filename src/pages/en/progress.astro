---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import LearningMap from '../../components/LearningMap';
import { getCopy } from '../../utils/i18n';

const locale = 'en';
const copy = getCopy(locale);
const alternatePath = '/progress/';
---

<Layout
  title={`Progress | ${copy.brand.name}`}
  description={copy.seo.description}
  lang={locale}
  canonicalPath="/en/progress/"
  alternatePath={alternatePath}
>
  <main class="site-shell">
    <SiteHeader locale={locale} alternatePath={alternatePath} />

    <section class="mx-auto mt-10 w-full max-w-6xl" data-reveal>
      <div class="rounded-xl bg-black px-8 py-14 text-white sm:px-12 sm:py-20">
        <p class="soft-label mb-5">Progress</p>
        <h1 class="hero-title max-w-4xl font-semibold">Learning Progress (Left to Right)</h1>
        <p class="mt-5 max-w-3xl text-[17px] leading-[1.47] text-white/82">
          The map expands by depth from left to right: each column groups parallel capabilities, while progression unfolds across columns.
        </p>
      </div>
    </section>

    <section class="mx-auto mb-14 mt-6 w-full max-w-6xl" data-reveal>
      <div class="panel overflow-hidden rounded-xl bg-[#f5f5f7]">
        <div class="relative w-full h-[70vh] sm:h-[78vh]">
          <LearningMap client:load />
        </div>
      </div>
    </section>

    <section class="mx-auto mb-24 w-full max-w-6xl" data-reveal>
      <div class="rounded-xl bg-[#f5f5f7] p-8 sm:p-12">
        <p class="section-kicker">Internship Goal</p>
        <h2 class="section-title mt-3">Internship target at progression convergence</h2>

        <div class="mt-8 border-t border-black/12">
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-[#1d1d1f]">Foundation Layer (Sequential)</div>
            <div>Math, programming, and systems fundamentals build the prerequisite depth for later stages.</div>
          </article>
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-[#1d1d1f]">Specialized Layer (Parallel)</div>
            <div>Algorithms, systems, and model capabilities advance in parallel and are combined downstream.</div>
          </article>
          <article class="data-row md:grid-cols-[1.2fr_2fr]">
            <div class="font-semibold text-[#1d1d1f]">Research Internship Convergence Goal</div>
            <div>Google / Meta / Jane Street and other top international internships as the final target.</div>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

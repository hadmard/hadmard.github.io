---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { getCopy } from '../../utils/i18n';

const locale = 'en';
const copy = getCopy(locale);
const alternatePath = '/' + 'projects/';
---

<Layout
    title={`${copy.nav.find((i) => i.id === 'projects')?.label || 'projects'} | ${copy.brand.name}`}
    description={copy.seo.description}
    lang={locale}
    canonicalPath="/en/projects/"
    alternatePath={alternatePath}
>
    <main class="site-shell">
        <SiteHeader locale={locale} alternatePath={alternatePath} />

        <section id="projects" class="mx-auto mt-12 mb-8 w-full max-w-5xl" data-reveal>
            <div class="panel-strong p-8 sm:p-12">
                <p class="soft-label mb-5">Google Color System · Apple Minimal Surfaces</p>
                <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{copy['projects']?.title || 'projects'}</h1>
                <p class="mt-4 max-w-3xl text-slate-600 leading-8">{copy['projects']?.intro || ''}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                    <span class="signal-pill">Clear hierarchy</span>
                    <span class="signal-pill">Soft motion</span>
                    <span class="signal-pill">Consistent accents</span>
                </div>
            </div>
        </section>

        <section class="mx-auto mb-24 w-full max-w-5xl" data-reveal>
            <div class="panel p-8 sm:p-10">
                <h2 class="text-xl font-semibold text-slate-900">Page Notes</h2>
                <p class="mt-3 text-slate-600 leading-8">
                    The page now follows a readable light surface design, fixing the white-on-white/white-on-light contrast issues from the previous style.
                </p>
                <p class="mt-3 text-slate-600 leading-8">
                    You can now add real project cards on top of this baseline without reworking the visual system again.
                </p>
                </div>
        </section>
    </main>
</Layout>
